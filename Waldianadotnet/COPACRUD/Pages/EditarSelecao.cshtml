@page
@model CopaCrud.Pages.EditarSelecaoModel


<div class="container mt-5">


    <h1 class="mb-4"> Editar Seleção </h1>
    <form method="post">
        <input asp-for="Selecao.Id" type="hidden">


        <div class="mb-3">
            <label class="form-label"> Nome da Seleção </label>
            <input asp-for="Selecao.Nome" class="form-control">
        </div>


        <div class="mb-3">
            <label class="form-label"> Grupo </label>
            <input asp-for="Selecao.Grupo" class="form-control">
        </div>


        <div class="mb-3">
            <label class="form-label"> Continente </label>
            <input asp-for="Selecao.Continente" class="form-control">
        </div>


        <div class="mb-3">
            <label class="form-label"> Títulos </label>
            <input asp-for="Selecao.Titulos" class="form-control">
        </div>


        <button class="btn btn-warning"> Atualizar </button>


        <a href="/Selecoes" class="btn btn-secondary"> Voltar </a>
    </form>
</div>


