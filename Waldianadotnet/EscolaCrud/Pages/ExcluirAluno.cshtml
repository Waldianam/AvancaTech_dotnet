@page
@model EscolaCrud.Pages.ExcluirAlunoModel


<div class="container mt-5">
    <h1 class="text-danger mb-4"> Excluir Aluno </h1>


    <div class="alert alert-danger"> Tem certeza que deseja excluir este aluno? </div>


    <form method="post">
        <input asp-for="Aluno.Id" type="hidden">


        <div class="mb-3">
            <label class="form-label"> Nome </label>
            <input asp-for="Aluno.Nome" class="form-control" readonly>
        </div>


        <div class="mb-3">
            <label class="form-label"> Email </label>
            <input asp-for="Aluno.Email" class="form-control" readonly>
        </div>


        <div class="mb-3">
            <label class="form-label"> Telefone </label>
            <input asp-for="Aluno.Telefone" class="form-control" readonly>
        </div>


        <div class="mb-3">
            <label class="form-label"> Endereço </label>
            <input asp-for="Aluno.Endereco" class="form-control" readonly>

            <div class="mb-3">
            <label class="form-label"> Unidades </label>
            <input asp-for="Aluno.Unidades" class="form-control" readonly>

            <div class="mb-3">
            <label class="form-label"> Série </label>
            <input asp-for="Aluno.Serie" class="form-control" readonly>




        </div>


        <button class="btn btn-danger"> Confirmar Exclusão </button>


        <a href="/Selecoes" class="btn btn-secondary"> Cancelar </a>
    </form>
</div>




