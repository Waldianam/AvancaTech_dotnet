@page
@model EscolaCrud.Pages.CadastrarAlunoModel


<div class="container mt-5">
    <h1 class="mb-4"> Cadastrar Aluno </h1>
    <form method="post">
        <div class="mb-3">
            <label class="form-label"> Nome do Aluno </label>
            <input asp-for="Aluno.Nome" class="form-control">
        </div>


        <div class="mb-3">
            <label class="form-label"> Email </label>
            <input asp-for="Aluno.Email" class="form-control">
        </div>


        <div class="mb-3">
            <label class="form-label"> Telefone </label>
            <input asp-for="Aluno.Telefone" class="form-control" type="number">
        </div>


        <div class="mb-3">
            <label class="form-label"> Endereço </label>
            <input asp-for="Aluno.Endereco" class="form-control" type="text">
        </div>

        <button class="btn btn-success"> Salvar </button>
        <a href="/aluno" class="btn btn-secondary"> Voltar </a>
    </form>
</div>
