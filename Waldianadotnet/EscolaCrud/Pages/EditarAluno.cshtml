@page
@model EscolaCrud.Pages.EditarAlunoModel


<div class="container mt-5">


    <h1 class="mb-4"> Editar Aluno </h1>
    <form method="post">
        <input asp-for="Aluno.Id" type="hidden">


        <div class="mb-3">
            <label class="form-label"> Nome do Aluno </label>
            <input asp-for="Aluno.Nome" class="form-control">
        </div>


        <div class="mb-3">
            <label class="form-label"> Email </label>
            <input asp-for="Aluno.Email" class="form-control">
        </div>


        <div class="mb-3">
            <label class="form-label"> Telefone </label>
            <input asp-for="Aluno.Telefone" class="form-control">
        </div>


        <div class="mb-3">
            <label class="form-label"> Endereço </label>
            <input asp-for="Aluno.Endereco" class="form-control">
        </div>
        
        <div class="mb-3">
            <label class="form-label"> Unidades </label>
            <input asp-for="Aluno.Unidades" class="form-control">
        </div>
        <div class="mb-3">
            <label class="form-label"> Serie </label>
            <input asp-for="Aluno.Serie" class="form-control" type="text">
        </div>

        <button class="btn btn-warning"> Atualizar </button>
        <a href="/Aluno" class="btn btn-secondary"> Voltar </a>
    </form>
</div>


